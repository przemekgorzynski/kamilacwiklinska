---
import CookieBanner from '../components/CookieBanner.astro';
import { contact } from '../data/content';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Fotograf Kamila Ćwiklińska – Aleksandrów Kujawski, Toruń, Włocławek',
  description = 'Fotografia: sesje rodzinne, dziecięce, ciążowe, noworodkowe, ślubne, plenerowe i kobiece. Aleksandrów Kujawski, Toruń, Włocławek, Ciechocinek i okolice.',
  ogImage = '/back/2.jpg',
} = Astro.props;

const SITE = 'https://kamilacwiklinska.com';
const ogImageAbs = ogImage.startsWith('http') ? ogImage : `${SITE}${ogImage}`;
const canonical = new URL(Astro.url.pathname, SITE).href;

// Areas served and sessions offered — reused in keywords and structured data
const AREAS = ['Aleksandrów Kujawski', 'Toruń', 'Włocławek', 'Ciechocinek'];
const SESSIONS = [
  'fotografia rodzinna', 'sesje dziecięce', 'sesje ciążowe', 'sesje noworodkowe',
  'fotografia ślubna', 'sesje plenerowe', 'sesje kobiece',
];
const keywords = [
  ...AREAS.map(a => `fotograf ${a}`),
  ...SESSIONS,
  'Kamila Ćwiklińska', 'studio fotograficzne',
].join(', ');

const [street, locality] = contact.address.split(',').map(s => s.trim());
const postalMatch = locality.match(/\d{2}-\d{3}/);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Photographer',
  name: contact.name,
  description,
  image: `${SITE}/images/logo.png`,
  url: SITE,
  telephone: contact.phone.replace(/[\s-]/g, ''),
  email: contact.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: street,
    postalCode: postalMatch ? postalMatch[0] : undefined,
    addressLocality: locality.replace(/\d{2}-\d{3}/, '').trim(),
    addressCountry: 'PL',
  },
  areaServed: AREAS.map(name => ({ '@type': 'City', name })),
  knowsAbout: SESSIONS,
  priceRange: '$$',
  sameAs: [contact.social.facebook, contact.social.instagram],
};
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Lato:wght@300;400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content="pl_PL" />
    <meta property="og:site_name"   content="Studio Fotograficzne Kamila Ćwiklińska" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImageAbs} />
    <meta property="og:image:width"  content="2048" />
    <meta property="og:image:height" content="1365" />
    <meta property="og:url"         content={SITE} />

    <!-- WhatsApp / Twitter card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageAbs} />

    <!-- Structured data for local SEO -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="bg-stone-950 text-stone-100 font-sans antialiased">
    <slot />
    <CookieBanner />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  * {
    box-sizing: border-box;
  }

  ::-webkit-scrollbar {
    width: 6px;
  }

  ::-webkit-scrollbar-track {
    background: #0c0c0c;
  }

  ::-webkit-scrollbar-thumb {
    background: #b08d57;
    border-radius: 3px;
  }
</style>
