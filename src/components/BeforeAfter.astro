---
// Replace these paths with your actual before/after images in public/images/
const before = '/images/gallery/kobiece/' + 'kobiece_1.webp';
const after  = '/images/gallery/plenerowe/' + 'plenerowe_1.webp';
---

<section class="py-24 lg:py-32 bg-stone-950">
  <div class="max-w-5xl mx-auto px-6 lg:px-8">

    <div class="text-center mb-12">
      <p class="text-xs tracking-[0.3em] uppercase text-gold mb-3">Efekt retuszu</p>
      <h2 class="font-serif text-4xl md:text-5xl font-light text-stone-100">Przed / Po</h2>
      <p class="text-stone-500 text-sm mt-3 font-light">Przeciągnij suwak, aby zobaczyć różnicę</p>
    </div>

    <div
      id="ba-container"
      class="relative overflow-hidden select-none cursor-ew-resize"
      style="aspect-ratio: 3/2;"
    >
      <!-- Before -->
      <img
        id="ba-before"
        src={before}
        alt="Przed retuszem"
        class="absolute inset-0 w-full h-full object-cover"
        draggable="false"
      />

      <!-- After (clipped) -->
      <div id="ba-after-wrap" class="absolute inset-0 overflow-hidden" style="width:50%;">
        <img
          src={after}
          alt="Po retuszu"
          class="absolute inset-0 h-full object-cover"
          style="width:var(--ba-full-w, 100vw); max-width:none;"
          draggable="false"
          id="ba-after-img"
        />
      </div>

      <!-- Labels -->
      <span class="absolute top-4 left-4 text-[10px] tracking-[0.25em] uppercase text-white/70 bg-black/40 px-2 py-1 pointer-events-none">Przed</span>
      <span class="absolute top-4 right-4 text-[10px] tracking-[0.25em] uppercase text-white/70 bg-black/40 px-2 py-1 pointer-events-none">Po</span>

      <!-- Handle -->
      <div
        id="ba-handle"
        class="absolute top-0 bottom-0 flex flex-col items-center pointer-events-none"
        style="left:50%; transform:translateX(-50%);"
      >
        <div class="w-px flex-1 bg-white/70"></div>
        <div class="w-9 h-9 rounded-full bg-white shadow-lg flex items-center justify-center flex-shrink-0 my-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1c1c1c" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8 3 4 7l4 4M16 3l4 4-4 4"/>
            <line x1="4" y1="7" x2="20" y2="7"/>
          </svg>
        </div>
        <div class="w-px flex-1 bg-white/70"></div>
      </div>
    </div>
  </div>
</section>

<script>
  const container = document.getElementById('ba-container')!;
  const handle    = document.getElementById('ba-handle')!;
  const afterWrap = document.getElementById('ba-after-wrap')!;
  const afterImg  = document.getElementById('ba-after-img')!;

  function setFullWidth() {
    const w = container.getBoundingClientRect().width;
    afterImg.style.width = `${w}px`;
  }
  setFullWidth();
  window.addEventListener('resize', setFullWidth);

  function move(clientX: number) {
    const rect = container.getBoundingClientRect();
    const pct  = Math.min(Math.max(0, (clientX - rect.left) / rect.width * 100), 100);
    handle.style.left = `${pct}%`;
    afterWrap.style.width = `${pct}%`;
  }

  let dragging = false;
  container.addEventListener('mousedown',  () => { dragging = true; });
  window.addEventListener('mouseup',   () => { dragging = false; });
  window.addEventListener('mousemove', e  => { if (dragging) move(e.clientX); });

  container.addEventListener('touchstart', e => { dragging = true; move(e.touches[0].clientX); }, { passive: true });
  window.addEventListener('touchend',   () => { dragging = false; });
  window.addEventListener('touchmove',  e  => { if (dragging) move(e.touches[0].clientX); }, { passive: true });

  // Initial click
  container.addEventListener('click', e => move(e.clientX));
</script>
