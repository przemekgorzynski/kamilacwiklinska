---
const navLinks = [
  { href: '#uslugi', label: 'Usługi' },
  { href: '#galeria', label: 'Galeria' },
  { href: '#opinie', label: 'Opinie' },
  { href: '#o-mnie', label: 'O mnie' },
  { href: '#kontakt', label: 'Kontakt' },
];
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" style="background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, transparent 100%);">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-18 py-4">

      <a href="#" aria-label="Strona główna — Kamila Ćwiklińska Fotografia" class="block" style="filter:drop-shadow(0 1px 4px rgba(0,0,0,0.55));">
        <img src="/images/logo.png" alt="Kamila Ćwiklińska Fotografia" class="h-10 md:h-12 w-auto" width="212" height="120" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="nav-link text-xs font-light tracking-[0.2em] uppercase text-white/90 hover:text-white transition-colors duration-200" style="text-shadow:0 1px 4px rgba(0,0,0,0.6);"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Social icons -->
      <div class="hidden md:flex items-center gap-4">
        <a href="https://www.facebook.com/profile.php?id=100075784977782" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="nav-icon text-white/80 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://www.instagram.com/fotografiakamilacwiklinska/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="nav-icon text-white/80 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="https://wa.me/48695982588" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="nav-icon text-white/80 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
        </a>
      </div>

      <!-- Mobile toggle -->
      <button id="mobile-toggle" class="md:hidden text-white p-2 -mr-2" aria-label="Otwórz menu" aria-expanded="false">
        <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="hidden">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-stone-900/97 backdrop-blur-md">
    <nav class="px-6 py-4 flex flex-col gap-1">
      {navLinks.map(link => (
        <a href={link.href} class="mobile-nav-link block py-3 text-sm tracking-[0.2em] uppercase text-white/90 border-b border-white/10 last:border-0">
          {link.label}
        </a>
      ))}
      <div class="flex gap-5 pt-4">
        <a href="https://www.facebook.com/profile.php?id=100075784977782" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="text-white/70 hover:text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://www.instagram.com/fotografiakamilacwiklinska/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-white/70 hover:text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="https://wa.me/48695982588" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="text-white/70 hover:text-white">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar')!;
  const mobileToggle = document.getElementById('mobile-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconMenu = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;

  // Nav scroll state
  const SCROLLED_CLASSES = ['bg-stone-950/95', 'backdrop-blur-sm', 'shadow-sm'];

  function updateNav() {
    const scrolled = window.scrollY > 60;
    if (scrolled) {
      navbar.style.background = '';
      navbar.classList.add(...SCROLLED_CLASSES);
      document.querySelectorAll<HTMLElement>('.nav-link').forEach(el => {
        el.style.color = '';
        el.classList.remove('text-white/90');
        el.classList.add('!text-stone-100');
      });
      document.querySelectorAll<HTMLElement>('.nav-icon').forEach(el => {
        el.classList.remove('text-white/80', 'text-white');
        el.classList.add('!text-stone-300');
      });
      const logo = navbar.querySelector<HTMLElement>('a:first-child');
      if (logo) {
        logo.classList.remove('text-white');
        logo.classList.add('!text-stone-100');
      }
    } else {
      navbar.classList.remove(...SCROLLED_CLASSES);
      navbar.style.background = 'linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, transparent 100%)';
      document.querySelectorAll<HTMLElement>('.nav-link').forEach(el => {
        el.classList.remove('!text-stone-100');
        el.classList.add('text-white/90');
      });
      document.querySelectorAll<HTMLElement>('.nav-icon').forEach(el => {
        el.classList.remove('!text-stone-300');
        el.classList.add('text-white/80');
      });
      const logo = navbar.querySelector<HTMLElement>('a:first-child');
      if (logo) {
        logo.classList.remove('!text-stone-100');
        logo.classList.add('text-white');
      }
    }
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  // Mobile menu
  function toggleMobile() {
    const isOpen = !mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden');
    iconMenu.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    mobileToggle.setAttribute('aria-expanded', String(!isOpen));
  }

  mobileToggle.addEventListener('click', toggleMobile);
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      iconMenu.classList.remove('hidden');
      iconClose.classList.add('hidden');
    });
  });
</script>
