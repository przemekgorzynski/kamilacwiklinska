---
---

<section id="galeria" class="py-24 lg:py-32 bg-stone-950">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <div class="text-center mb-12">
      <p class="text-xs tracking-[0.3em] uppercase text-gold mb-3">Moje prace</p>
      <h2 class="font-serif text-4xl md:text-5xl font-light text-stone-100">Galeria</h2>
    </div>

    <div id="filter-bar" class="flex flex-wrap justify-center gap-2 mb-12 min-h-[40px]">
      <div class="text-stone-600 text-xs tracking-widest animate-pulse">Ładowanie…</div>
    </div>

    <div id="gallery-status" class="hidden text-center text-stone-400 text-sm py-12"></div>

    <div id="gallery-grid" class="grid grid-cols-2 md:grid-cols-3 gap-3 lg:gap-4">
      {Array.from({ length: 6 }).map(() => (
        <div class="aspect-[4/5] bg-stone-800 animate-pulse"></div>
      ))}
    </div>
  </div>
</section>

<!-- Lightbox -->
<div id="lightbox" class="fixed inset-0 z-50 hidden bg-black/95 items-center justify-center" role="dialog" aria-modal="true">
  <button id="lb-close" class="absolute top-4 right-4 text-white/70 hover:text-white p-2" aria-label="Zamknij">
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
  <button id="lb-prev" class="absolute left-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white p-2" aria-label="Poprzednie">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
  </button>
  <div class="w-full h-full flex items-center justify-center p-12 md:p-20">
    <img id="lb-img" src="" alt="" class="max-w-full max-h-full object-contain"/>
  </div>
  <button id="lb-next" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white p-2" aria-label="Następne">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
  </button>
  <div id="lb-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/50 text-xs tracking-widest"></div>
</div>

<style>
  /* :global — the filter buttons are created at runtime by JS, so they don't
     receive Astro's scoped data attribute and scoped selectors wouldn't match. */
  :global(.filter-btn) { transition: all 0.2s; border-color: #44403c; color: #a8a29e; }
  :global(.filter-btn:hover) { border-color: #b08d57; color: #b08d57; }
  :global(.filter-btn.active) { background-color: #b08d57; border-color: #b08d57; color: #1c1917; }
  :global(.filter-btn.active:hover) { color: #1c1917; }
  #lightbox:not(.hidden) { display: flex; }
</style>

<script>
  import { categories, labelFor } from '../data/categories';

  const PREVIEW_COUNT = 6;   // random photos across all categories in the default view
  const CATEGORY_LIMIT = 6;  // photos shown on-page per category (rest open the category page)
  const IMAGE_RE = /\.(jpg|jpeg|png|webp|gif|avif)$/i;
  const GALLERY_BASE = '/images/gallery/';

  interface NginxEntry { name: string; type: 'file' | 'directory'; mtime: string; size: number; }
  interface GalleryImage { category: string; label: string; src: string; }

  const filterBar = document.getElementById('filter-bar')!;
  const grid = document.getElementById('gallery-grid')!;
  const status = document.getElementById('gallery-status')!;

  const byCategory = new Map<string, GalleryImage[]>();
  let previewImages: GalleryImage[] = [];

  // Round-robin merge so a multi-folder category shows a mix of both
  function interleave<T>(arrs: T[][]): T[] {
    const out: T[] = [];
    const max = Math.max(0, ...arrs.map(a => a.length));
    for (let i = 0; i < max; i++) for (const a of arrs) if (i < a.length) out.push(a[i]);
    return out;
  }

  function randomSample<T>(arr: T[], n: number): T[] {
    const copy = [...arr];
    for (let i = copy.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [copy[i], copy[j]] = [copy[j], copy[i]];
    }
    return copy.slice(0, n);
  }

  // ── Fetch helpers ───────────────────────────────────────────────────────────

  async function listDir(path: string): Promise<NginxEntry[]> {
    const res = await fetch(path);
    if (!res.ok) throw new Error(`${res.status} ${path}`);
    return res.json();
  }

  // ── Filters ─────────────────────────────────────────────────────────────────

  function renderFilters(categories: string[]) {
    filterBar.innerHTML = '';
    filterBar.appendChild(makeBtn('all', 'Wybrane', true));
    categories.forEach(cat => filterBar.appendChild(makeBtn(cat, labelFor(cat), false)));
  }

  function makeBtn(id: string, label: string, active: boolean): HTMLButtonElement {
    const btn = document.createElement('button');
    btn.className = `filter-btn text-xs tracking-[0.2em] uppercase px-5 py-2 border${active ? ' active' : ''}`;
    btn.textContent = label;
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      if (id === 'all') {
        renderGrid(previewImages, previewImages, null);
      } else {
        const full = byCategory.get(id) ?? [];
        renderGrid(full.slice(0, CATEGORY_LIMIT), full, id);
      }
    });
    return btn;
  }

  // ── Grid ────────────────────────────────────────────────────────────────────

  // displayImages: tiles shown on the page (a prefix of lbImages)
  // lbImages: the full set the lightbox navigates through
  // categorySlug: when set, the "+N" tile and a "Zobacz wszystkie" link open
  //   the dedicated category page (/galeria/<slug>) instead of the lightbox.
  function renderGrid(displayImages: GalleryImage[], lbImages: GalleryImage[], categorySlug: string | null) {
    grid.innerHTML = '';
    if (displayImages.length === 0) {
      showStatus('Brak zdjęć w tej kategorii.');
      return;
    }
    hideStatus();

    const hidden = lbImages.length - displayImages.length;
    const catUrl = categorySlug ? `/galeria/${categorySlug}/` : null;

    displayImages.forEach((img, i) => {
      // The last tile, when a category has more photos, links to its full page.
      const isMoreTile = !!catUrl && hidden > 0 && i === displayImages.length - 1;
      const tile = document.createElement(isMoreTile ? 'a' : 'button') as HTMLElement;
      tile.className = 'group relative block w-full aspect-[4/5] overflow-hidden bg-stone-900';
      tile.setAttribute('aria-label', isMoreTile ? `Zobacz wszystkie – ${img.label}` : img.label);

      const el = document.createElement('img');
      el.src = img.src;
      el.alt = img.label;
      el.className = 'w-full h-full object-cover group-hover:scale-105 transition-transform duration-700';
      el.loading = 'lazy';
      el.onerror = () => tile.remove();
      tile.appendChild(el);

      if (isMoreTile) {
        (tile as HTMLAnchorElement).href = catUrl!;
        const overlay = document.createElement('div');
        overlay.className = 'absolute inset-0 flex items-center justify-center bg-black/55 text-white font-serif text-2xl tracking-wide transition-colors duration-300 group-hover:bg-black/65';
        overlay.textContent = `+${hidden}`;
        tile.appendChild(overlay);
      } else {
        tile.addEventListener('click', () => openLightbox(i, lbImages));
      }

      grid.appendChild(tile);
    });
  }

  // ── Load ────────────────────────────────────────────────────────────────────

  async function load() {
    try {
      const entries = await listDir(GALLERY_BASE);
      const present = new Set(entries.filter(e => e.type === 'directory').map(e => e.name));
      // Featured categories that have at least one present folder, in defined order
      const cats = categories.filter(c => c.featured && c.folders.some(f => present.has(f)));

      if (cats.length === 0) {
        showStatus('Brak folderów w galerii. Zamontuj zdjęcia do /images/gallery/');
        filterBar.innerHTML = '';
        grid.innerHTML = '';
        return;
      }

      const results = await Promise.allSettled(
        cats.map(async cat => {
          // Aggregate files across all of the category's folders
          const perFolder = await Promise.all(
            cat.folders.filter(f => present.has(f)).map(async f => {
              const files = await listDir(`${GALLERY_BASE}${f}/`);
              return files
                .filter(file => file.type === 'file' && IMAGE_RE.test(file.name))
                .map(file => ({ category: cat.slug, label: cat.label, src: `${GALLERY_BASE}${f}/${file.name}` }));
            })
          );
          return { slug: cat.slug, images: interleave(perFolder) };
        })
      );

      const populated: string[] = [];
      const allImages: GalleryImage[] = [];
      results.forEach(r => {
        if (r.status === 'fulfilled' && r.value.images.length > 0) {
          byCategory.set(r.value.slug, r.value.images);
          allImages.push(...r.value.images);
          populated.push(r.value.slug);
        }
      });

      // Default view: a random selection from across all categories
      previewImages = randomSample(allImages, PREVIEW_COUNT);

      renderFilters(populated);

      renderGrid(previewImages, previewImages, null);

    } catch (err) {
      console.error(err);
      showStatus('Nie udało się załadować galerii.');
      grid.innerHTML = '';
      filterBar.innerHTML = '';
    }
  }

  function showStatus(msg: string) { status.textContent = msg; status.classList.remove('hidden'); }
  function hideStatus() { status.classList.add('hidden'); }

  load();

  // ── Lightbox ────────────────────────────────────────────────────────────────

  const lightbox = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  const lbCounter = document.getElementById('lb-counter')!;
  let lbSet: GalleryImage[] = [];
  let lbIdx = 0;

  function openLightbox(i: number, images: GalleryImage[]) {
    lbSet = images; lbIdx = i;
    showLb();
    lightbox.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  function showLb() {
    lbImg.src = lbSet[lbIdx].src;
    lbImg.alt = lbSet[lbIdx].label;
    lbCounter.textContent = `${lbIdx + 1} / ${lbSet.length}`;
  }
  function closeLb() { lightbox.classList.add('hidden'); document.body.style.overflow = ''; lbImg.src = ''; }

  document.getElementById('lb-close')!.addEventListener('click', closeLb);
  document.getElementById('lb-prev')!.addEventListener('click', () => { lbIdx = (lbIdx - 1 + lbSet.length) % lbSet.length; showLb(); });
  document.getElementById('lb-next')!.addEventListener('click', () => { lbIdx = (lbIdx + 1) % lbSet.length; showLb(); });
  lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLb(); });
  document.addEventListener('keydown', e => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLb();
    if (e.key === 'ArrowLeft') { lbIdx = (lbIdx - 1 + lbSet.length) % lbSet.length; showLb(); }
    if (e.key === 'ArrowRight') { lbIdx = (lbIdx + 1) % lbSet.length; showLb(); }
  });
  let tx = 0;
  lightbox.addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, { passive: true });
  lightbox.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - tx;
    if (Math.abs(dx) > 50) { lbIdx = dx < 0 ? (lbIdx + 1) % lbSet.length : (lbIdx - 1 + lbSet.length) % lbSet.length; showLb(); }
  });
</script>
