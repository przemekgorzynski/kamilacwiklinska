---
import fs from 'node:fs';
import path from 'node:path';

// Read the hero/background images at build time so the first slide is in the
// HTML (good LCP, works even if JS is slow/blocked). They are baked into the
// image from public/back, so the filesystem list is accurate at build.
const IMAGE_RE = /\.(jpg|jpeg|png|webp|gif|avif)$/i;
let slides: string[] = [];
try {
  const dir = path.join(process.cwd(), 'public', 'back');
  slides = fs.readdirSync(dir).filter(f => IMAGE_RE.test(f)).sort().map(f => `/back/${f}`);
} catch { /* no back/ dir at build — hero stays on its dark background */ }
---

<section id="hero" style="position:relative;height:100vh;min-height:600px;overflow:hidden;background:#1c1c1c;">

  <div id="hero-slides" style="position:absolute;inset:0;">
    {slides.map((src, i) => (
      <div class="hero-slide" style={`position:absolute;inset:0;opacity:${i === 0 ? '1' : '0'};transition:opacity 1s;`}>
        <img
          src={src}
          alt=""
          style="width:100%;height:100%;object-fit:cover;display:block;"
          loading="eager"
          fetchpriority={i === 0 ? 'high' : 'low'}
        />
      </div>
    ))}
  </div>

  <div style="position:absolute;inset:0;background:rgba(0,0,0,0.45);z-index:1;"></div>

  <div style="position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;text-align:center;padding:0 1.5rem;">
    <p class="font-sans text-xs tracking-[0.35em] uppercase text-white/70 mb-4">Studio Fotograficzne</p>
    <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl font-light text-white mb-6 leading-tight">
      Kamila<br /><em>Ćwiklińska</em>
    </h1>
    <p class="font-sans text-sm md:text-base font-light tracking-widest text-white/80 mb-10 uppercase">
      Fotograf z pasji
    </p>
    <a href="#kontakt" class="inline-block border border-white/60 text-white text-xs tracking-[0.25em] uppercase px-8 py-3 hover:bg-white hover:text-stone-900 transition-all duration-300">
      Umów sesję
    </a>
  </div>

  <div id="hero-dots" style="position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);z-index:2;display:flex;gap:0.5rem;">
    {slides.length > 1 && slides.map((_, i) => (
      <button
        class="hero-dot"
        data-i={i}
        aria-label={`Slajd ${i + 1}`}
        style={`height:0.5rem;border-radius:9999px;border:none;cursor:pointer;transition:all 0.3s;width:${i === 0 ? '1.5rem' : '0.5rem'};background:${i === 0 ? 'white' : 'rgba(255,255,255,0.4)'};`}
      ></button>
    ))}
  </div>

  <div class="absolute bottom-8 right-8 z-10 hidden md:flex flex-col items-center gap-2" style="z-index:2;">
    <span class="text-white/50 text-[10px] tracking-[0.3em] uppercase rotate-90 origin-center mb-6">Scroll</span>
    <div class="w-px h-16 bg-gradient-to-b from-white/50 to-transparent"></div>
  </div>
</section>

<script>
  const slides = Array.from(document.querySelectorAll<HTMLElement>('.hero-slide'));
  const dots   = Array.from(document.querySelectorAll<HTMLButtonElement>('.hero-dot'));
  let current  = 0;
  let timer: ReturnType<typeof setInterval>;

  function setDot(btn: HTMLButtonElement, active: boolean) {
    btn.style.width = active ? '1.5rem' : '0.5rem';
    btn.style.background = active ? 'white' : 'rgba(255,255,255,0.4)';
  }

  function goTo(index: number) {
    slides[current].style.opacity = '0';
    if (dots[current]) setDot(dots[current], false);
    current = index;
    slides[current].style.opacity = '1';
    if (dots[current]) setDot(dots[current], true);
  }

  function startTimer() {
    if (slides.length <= 1) return;
    timer = setInterval(() => goTo((current + 1) % slides.length), 5000);
  }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => { clearInterval(timer); goTo(i); startTimer(); });
  });

  startTimer();

  const hero = document.getElementById('hero')!;
  hero.addEventListener('mouseenter', () => clearInterval(timer));
  hero.addEventListener('mouseleave', startTimer);
</script>
