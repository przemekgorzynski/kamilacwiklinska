---
const year = new Date().getFullYear();
---

<footer class="bg-stone-950 text-white/40 py-12">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 flex flex-col items-center gap-6">

    <img src="/images/logo.png" alt="Kamila Ćwiklińska" class="h-16 w-auto opacity-70 hover:opacity-100 transition-opacity duration-300" />

    <div class="flex gap-6 text-xs font-light tracking-wide">
      <a href="#uslugi" class="hover:text-white/70 transition-colors">Usługi</a>
      <a href="#galeria" class="hover:text-white/70 transition-colors">Galeria</a>
      <a href="#kontakt" class="hover:text-white/70 transition-colors">Kontakt</a>
    </div>

    <p class="text-xs font-light tracking-wide">
      &copy; {year} Studio Fotograficzne Kamila Ćwiklińska. Wszelkie prawa zastrzeżone.
    </p>
    <a href="/polityka-prywatnosci" class="text-xs font-light text-stone-600 hover:text-stone-400 transition-colors">
      Polityka prywatności
    </a>
  </div>
</footer>
