---
import { contact } from '../data/content';
---

<section id="kontakt" class="py-24 lg:py-32 bg-stone-900 text-white">
  <div class="max-w-5xl mx-auto px-6 lg:px-8">

    <div class="text-center mb-16">
      <p class="text-xs tracking-[0.3em] uppercase text-gold mb-3">Skontaktuj się</p>
      <h2 class="font-serif text-4xl md:text-5xl font-light mb-6">Kontakt</h2>
      <p class="font-sans font-light text-white/60 max-w-xl mx-auto text-sm leading-relaxed">
        Nie czekaj! Jeśli chcesz zapisać się na sesję lub podjąć dłuższą współpracę,
        aby zaprezentować swój produkt lub markę podczas moich sesji — napisz do mnie.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20">

      <!-- Contact details -->
      <div class="space-y-6">
        <div class="flex items-start gap-4">
          <div class="text-gold mt-0.5 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <p class="text-xs tracking-widest uppercase text-white/40 mb-1">Adres</p>
            <p class="font-light text-white/80">{contact.address}</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="text-gold mt-0.5 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.25h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.5a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 14.92z"/></svg>
          </div>
          <div>
            <p class="text-xs tracking-widest uppercase text-white/40 mb-1">Telefon</p>
            <a href={`tel:${contact.phone.replace(/\s/g, '')}`} class="font-light text-white/80 hover:text-white transition-colors">
              {contact.phone}
            </a>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="text-gold mt-0.5 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <p class="text-xs tracking-widest uppercase text-white/40 mb-1">E-mail</p>
            <a href={`mailto:${contact.email}`} class="font-light text-white/80 hover:text-white transition-colors">
              {contact.email}
            </a>
          </div>
        </div>

        <!-- Social links -->
        <div class="pt-6 border-t border-white/10">
          <p class="text-xs tracking-widest uppercase text-white/40 mb-4">Znajdź mnie</p>
          <div class="flex gap-5">
            <a href={contact.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook"
               class="flex items-center gap-2 text-white/60 hover:text-white transition-colors text-sm font-light">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              Facebook
            </a>
            <a href={contact.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram"
               class="flex items-center gap-2 text-white/60 hover:text-white transition-colors text-sm font-light">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              Instagram
            </a>
            <a href={contact.social.whatsapp} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp"
               class="flex items-center gap-2 text-white/60 hover:text-white transition-colors text-sm font-light">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
              WhatsApp
            </a>
          </div>
        </div>
      </div>

      <!-- Quick contact CTA -->
      <div class="flex flex-col justify-center">
        <div class="bg-white/5 border border-white/10 p-8 lg:p-10">
          <h3 class="font-serif text-2xl font-light mb-4">Napisz do mnie</h3>
          <p class="text-white/50 text-sm font-light leading-relaxed mb-8">
            Najszybciej odpowiem przez WhatsApp lub Instagram. Chętnie odpowiem na wszystkie pytania i ustalimy szczegóły Twojej sesji.
          </p>
          <div class="flex flex-col gap-3">
            <a
              href={contact.social.whatsapp}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-3 bg-[#25d366] text-white text-xs tracking-[0.2em] uppercase px-6 py-4 hover:bg-[#1db954] transition-colors duration-200"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
              WhatsApp
            </a>
            <a
              href={`mailto:${contact.email}`}
              class="flex items-center justify-center gap-3 border border-white/20 text-white/80 text-xs tracking-[0.2em] uppercase px-6 py-4 hover:bg-white/10 transition-colors duration-200"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              E-mail
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Google Maps -->
    <div class="mt-16 overflow-hidden border border-white/10" style="height:320px;">
      <iframe
        title="Lokalizacja studia"
        src="https://maps.google.com/maps?q=Plebanka+2A,+87-700+Plebanka,+Polska&output=embed&hl=pl&z=14"
        width="100%"
        height="100%"
        style="border:0;filter:grayscale(1) invert(0.85) contrast(0.9);"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>
</section>
